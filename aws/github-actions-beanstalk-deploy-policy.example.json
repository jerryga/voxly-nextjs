{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BeanstalkDeployBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::<DEPLOY_BUCKET_NAME>"
    },
    {
      "Sid": "BeanstalkDeployBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::<DEPLOY_BUCKET_NAME>/*"
    },
    {
      "Sid": "BeanstalkApplicationVersionAndEnv",
      "Effect": "Allow",
      "Action": [
        "elasticbeanstalk:CreateApplicationVersion",
        "elasticbeanstalk:UpdateEnvironment",
        "elasticbeanstalk:DescribeApplications",
        "elasticbeanstalk:DescribeApplicationVersions",
        "elasticbeanstalk:DescribeEnvironments",
        "elasticbeanstalk:DescribeEvents"
      ],
      "Resource": "*"
    }
  ]
}
