project_id      = "your-gcp-project-id"
region          = "northamerica-northeast1"
service_name    = "voxly"
container_image = "northamerica-northeast1-docker.pkg.dev/your-gcp-project-id/voxly/voxly:latest"

min_instance_count = 0
max_instance_count = 3
container_port     = 8080
timeout_seconds    = 900
cpu                = "1"
memory             = "512Mi"

allow_unauthenticated = true

plain_env_vars = {
  NEXTAUTH_URL                  = "https://your-cloud-run-url-or-domain"
  ALLOWED_ORIGINS               = "https://your-cloud-run-url-or-domain"
  AWS_REGION                    = "ca-central-1"
  S3_BUCKET                     = "your-existing-s3-bucket"
  STRIPE_PRICE_STARTER_MONTHLY  = "price_replace_me"
  STRIPE_PRICE_PRO_MONTHLY      = "price_replace_me"
  STRIPE_PRICE_TEAM_MONTHLY     = "price_replace_me"
  STRIPE_PRICE_TOPUP_100        = "price_replace_me"
  STRIPE_PRICE_TOPUP_500        = "price_replace_me"
  EMAIL_FROM                    = "Voxly <no-reply@example.com>"
  ADMIN_EMAILS                  = "admin@example.com"
}

secret_env_vars = {
  NEXTAUTH_SECRET      = "voxly-nextauth-secret"
  DATABASE_URL         = "voxly-database-url"
  STRIPE_SECRET_KEY    = "voxly-stripe-secret-key"
  STRIPE_WEBHOOK_SECRET = "voxly-stripe-webhook-secret"
  DEEPGRAM_API_KEY     = "voxly-deepgram-api-key"
  OPENAI_API_KEY       = "voxly-openai-api-key"
  GOOGLE_GEMINI_API_KEY = "voxly-google-gemini-api-key"
  INNGEST_EVENT_KEY    = "voxly-inngest-event-key"
  INNGEST_SIGNING_KEY  = "voxly-inngest-signing-key"
}
