generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
  transcriptions Transcription[]
  projects       Project[]
  summaryTemplates SummaryTemplate[]
  assistantMessages AssistantMessage[]
  actionTasks    ActionTask[]
  subscription   Subscription?
  creditTransactions CreditTransaction[]
  promoRedemptions PromotionRedemption[]
}

model SummaryTemplate {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  slug               String
  baseTemplate       String   @default("default")
  promptInstructions String   @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId, createdAt])
  @@unique([userId, slug])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Project {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?         @db.Text
  color         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  transcriptions Transcription[]

  @@index([userId, createdAt])
  @@unique([userId, name])
}

model Transcription {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  fileName String
  fileUrl  String
  template String @default("default")
  status   String @default("processing")
  searchText String? @db.Text
  decisions   Json?
  keyPoints   Json?
  nextSteps   Json?
  actionItems Json?
  rawTranscript String? @db.Text
  formattedTranscript String? @db.Text
  transcript String? @db.Text
  duration   Int?
  assistantMessages AssistantMessage[]
  actionTasks ActionTask[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, createdAt])
  @@index([userId, projectId, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, template, createdAt])
  @@index([status])
}

model ActionTask {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcriptionId   String
  transcription     Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)
  title             String
  status            String        @default("open")
  priority          String        @default("MEDIUM")
  assignee          String?
  dueDate           DateTime?
  sourceActionIndex Int?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  completedAt       DateTime?

  @@index([userId, createdAt])
  @@index([transcriptionId, createdAt])
  @@index([transcriptionId, status, createdAt])
}

model AssistantMessage {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcriptionId String
  transcription   Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)
  role            String
  content         String        @db.Text
  createdAt       DateTime      @default(now())

  @@index([userId, transcriptionId, createdAt])
  @@index([transcriptionId, createdAt])
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  billingInterval        String    @default("monthly")
  cancelAtPeriodEnd      Boolean   @default(false)
  lastCreditRefreshAt    DateTime?
  status String @default("free")
  plan   String @default("free")
  creditsRemaining Int @default(0)
  creditsTotal     Int @default(0)
  monthlyCreditsRemaining Int @default(0)
  monthlyCreditsTotal     Int @default(0)
  topUpCreditsRemaining   Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String
  amount          Int
  balanceAfter    Int
  monthlyAfter    Int?
  topUpAfter      Int?
  transcriptionId String?
  stripeEventId   String?
  stripeInvoiceId String?
  stripeSessionId String?
  note            String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([stripeEventId])
}

model Promotion {
  id             String   @id @default(cuid())
  code           String   @unique
  status         String   @default("active")
  creditsAmount  Int
  startsAt       DateTime
  endsAt         DateTime
  maxRedemptions Int?
  newUsersOnly   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  redemptions    PromotionRedemption[]

  @@index([code, status])
}

model PromotionRedemption {
  id            String    @id @default(cuid())
  promotionId   String
  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditsGranted Int
  ipHash        String?
  userAgentHash String?
  createdAt     DateTime  @default(now())

  @@unique([promotionId, userId])
  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  status        String   @default("processing")
  error         String?
  processedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
